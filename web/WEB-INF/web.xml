<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>ControlTurnos</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- LOGIN -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- LOGOUT -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

    <!-- CU1 - MANTENIMIENTO DE USUARIOS Y AREAS -->
    <servlet>
        <servlet-name>EmpleadoServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.EmpleadoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmpleadoServlet</servlet-name>
        <url-pattern>/EmpleadoServlet</url-pattern>
    </servlet-mapping>

    <!-- CU2 - MARCAJE -->
    <servlet>
        <servlet-name>MarcajeServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.MarcajeServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MarcajeServlet</servlet-name>
        <url-pattern>/MarcajeServlet</url-pattern>
    </servlet-mapping>

    <!-- CU3 - ASIGNACION DE TURNOS -->
    <servlet>
        <servlet-name>AsignacionTurnoServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.AsignacionTurnoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AsignacionTurnoServlet</servlet-name>
        <url-pattern>/AsignacionTurnoServlet</url-pattern>
    </servlet-mapping>

    <!-- CU4 - GESTION DE SOLICITUDES (AdminArea y AdminRRHH) -->
    <servlet>
        <servlet-name>SolicitudServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.SolicitudServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SolicitudServlet</servlet-name>
        <url-pattern>/SolicitudServlet</url-pattern>
    </servlet-mapping>

    <!-- CU5 - GESTIONES DEL EMPLEADO -->
    <servlet>
        <servlet-name>EmpleadoGestionServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.EmpleadoGestionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>EmpleadoGestionServlet</servlet-name>
        <url-pattern>/EmpleadoGestionServlet</url-pattern>
    </servlet-mapping>

    <!-- REASIGNACION DIRECTA POR RRHH -->
    <servlet>
        <servlet-name>ReasignacionServlet</servlet-name>
        <servlet-class>controlTurnos.servlet.ReasignacionServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ReasignacionServlet</servlet-name>
        <url-pattern>/ReasignacionServlet</url-pattern>
    </servlet-mapping>

</web-app>
